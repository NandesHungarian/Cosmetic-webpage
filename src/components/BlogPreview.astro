---
import { getCollection } from 'astro:content';
import type { Locale } from '../i18n/v3/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

if (locale === 'ja' || locale === 'ko') return;

const slugOf = (id: string) => id.split('/').slice(1).join('/');

const allPosts = await getCollection('blog', ({ data }) => data.lang === locale);
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const blogBase = locale === 'hu' ? '/blog' : `/${locale}/blog`;
const postBase = locale === 'hu' ? '/blog' : `/${locale}/blog`;

const labels: Record<string, { eyebrow: string; heading: string; headingEm: string; headingEnd: string; sub: string; cta: string; readmore: string }> = {
  hu: {
    eyebrow: 'Tudástár',
    heading: 'Bőrápolási ',
    headingEm: 'tippek',
    headingEnd: ' és tanácsok',
    sub: 'Szakmai tartalmak a bőröd egészségéért és természetes ragyogásáért.',
    cta: 'Összes cikk',
    readmore: 'Elolvasom',
  },
  en: {
    eyebrow: 'Knowledge',
    heading: 'Skincare ',
    headingEm: 'tips',
    headingEnd: ' and advice',
    sub: 'Professional articles on skincare, treatments and conscious beauty routines.',
    cta: 'All articles',
    readmore: 'Read more',
  },
};

const l = labels[locale] ?? labels['hu'];
---

{posts.length > 0 && (
<section class="bp-section reveal">
  <div class="bp-inner">

    <header class="bp-header">
      <span class="eyebrow">{l.eyebrow}</span>
      <h2 class="bp-h2">{l.heading}<em>{l.headingEm}</em>{l.headingEnd}</h2>
      <p class="bp-sub">{l.sub}</p>
    </header>

    <div class="bp-grid">
      {posts.map((post) => (
        <a href={`${postBase}/${slugOf(post.id)}`} class="bp-card">
          <div class="bp-card-body">
            <time class="bp-date" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString(
                locale === 'hu' ? 'hu-HU' : 'en-GB',
                { year: 'numeric', month: 'long', day: 'numeric' }
              )}
            </time>
            <h3 class="bp-card-title">{post.data.title}</h3>
            <p class="bp-card-desc">{post.data.description}</p>
          </div>
          <span class="bp-card-cta">
            {l.readmore}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      ))}
    </div>

    <div class="bp-footer">
      <a href={blogBase} class="bp-cta">
        {l.cta}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>
)}

<style>
  .bp-section {
    background: var(--bg);
    padding: 10px var(--page-margin) 1.4rem;
  }

  .bp-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .bp-header .eyebrow {
    font-size: .525rem;
    margin-bottom: .74rem;
  }

  .bp-h2 {
    font-size: var(--section-h2);
    line-height: 1.08;
    margin: 0 0 .45rem;
  }

  .bp-h2 em {
    font-style: italic;
    color: var(--green);
  }

  .bp-sub {
    color: var(--muted);
    font-size: var(--section-sub);
    line-height: 1.45;
    max-width: 420px;
  }

  /* ── Kártyarács ── */
  .bp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(300px, 100%), 1fr));
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .bp-card {
    background: #fff;
    border-radius: 10px;
    border: 1px solid rgba(0,0,0,0.07);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.22s cubic-bezier(0.16,1,0.3,1),
                box-shadow 0.22s cubic-bezier(0.16,1,0.3,1);
  }
  .bp-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(80,100,60,0.09);
  }

  .bp-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bp-date {
    font-family: var(--sans);
    font-size: var(--section-label);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .bp-card-title {
    font-family: var(--serif);
    font-size: var(--section-body);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
  }

  .bp-card-desc {
    font-family: var(--sans);
    font-size: var(--section-label);
    color: var(--muted);
    line-height: 1.55;
  }

  .bp-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--sans);
    font-size: var(--section-label);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green);
  }

  /* ── "Összes cikk" link ── */
  .bp-footer {
    margin-top: 1.4rem;
  }

  .bp-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--sans);
    font-size: var(--section-label);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1.5px solid var(--green);
    padding-bottom: 2px;
    transition: color 0.18s;
  }
  .bp-cta:hover { color: var(--green); }
</style>
