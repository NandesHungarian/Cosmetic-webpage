---
// ░ Bőrelemzés CTA — a bemutatkozás (Rólam) UTÁN jelenik meg ░
// Korábban a Kezelések szekció alján volt; külön komponensbe áthelyezve, változatlan kinézettel.
// Az arc fotó helyét szaggatott keret jelöli. Scoped stílus, közös változók a global.css-ből.
---

<section class="boreelemzes">
  <div class="be-inner">
    <div class="be-photo"><span>Arc fotó</span></div>
    <div class="be-text">
      <p class="be-big">A bőröd többet tud elmondani magáról, mint gondolnád.</p>
      <p class="be-accent">Kezdd el a személyre szabott bőrelemzést!</p>
      <a href="#kapcsolat" class="be-btn">Időpontot foglalok</a>
    </div>
  </div>
</section>

<style>
  .boreelemzes{ background:var(--bg); padding:1.6rem 1.2rem 2.4rem; }
  .be-inner{ max-width:1000px; margin:0 auto; display:flex; align-items:center; gap:.9rem; }
  .be-photo{ flex-shrink:0; width:110px; height:110px; border:1.5px dashed var(--green); border-radius:12px; display:flex; align-items:center; justify-content:center; color:var(--green-deep); background:rgba(168,201,106,.06); font-size:.5rem; letter-spacing:.1em; text-transform:uppercase; text-align:center; }
  .be-text{ flex:1; min-width:0; }
  .be-big{ font-family:var(--serif); font-size:14px; line-height:1.2; color:var(--ink); }
  .be-accent{ color:var(--green-deep); font-size:.76rem; margin-top:.3rem; }
  .be-btn{ display:inline-flex; align-self:flex-start; margin-top:.7rem; border:1px solid var(--green); color:var(--green-deep); font-size:.62rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; padding:.6rem 1rem; border-radius:8px; }

  @media (min-width:760px){
    .boreelemzes{ padding:2rem 1.4rem 2.8rem; }
    .be-inner{ gap:2rem; }
    .be-photo{ width:auto; height:auto; flex:1; min-height:200px; }
    .be-text{ flex:1; }
    .be-big{ font-size:1.5rem; }
  }
</style>
