<!-- Scroll-reveal + Scroll-exit + Count-up JS — minden böngészőn működik -->
<script>
// ── 1. SCROLL REVEAL (belépő: .reveal → .in) ──
const revealObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('in');
      revealObs.unobserve(e.target);
    }
  });
}, { threshold: 0.06, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.reveal, .reveal-media').forEach(el => revealObs.observe(el));

// ── 2. SCROLL EXIT (kilépő: .scroll-exit → .exiting amikor eltűnik felfelé) ──
const exitObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (!e.isIntersecting && e.boundingClientRect.top < 0) {
      // Szekció felfelé gurult ki a képernyőről
      e.target.classList.add('exiting');
    } else {
      // Visszagörgetéskor visszaáll
      e.target.classList.remove('exiting');
    }
  });
}, { threshold: 0.05 });
document.querySelectorAll('.scroll-exit').forEach(el => exitObs.observe(el));

// ── 3. COUNT-UP ──
function easeOut(t) { return 1 - Math.pow(1 - t, 3); }
function countUp(el) {
  const target = parseFloat(el.dataset.target);
  const suffix = el.dataset.suffix || '';
  const duration = 2200;
  let start = null;
  function frame(ts) {
    if (!start) start = ts;
    const progress = Math.min((ts - start) / duration, 1);
    const val = Math.floor(easeOut(progress) * target);
    el.textContent = val + suffix;
    if (progress < 1) requestAnimationFrame(frame);
    else el.textContent = target + suffix;
  }
  requestAnimationFrame(frame);
}
const countObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      countUp(e.target);
      countObs.unobserve(e.target);
    }
  });
}, { threshold: 0.5 });
document.querySelectorAll('[data-target]').forEach(el => countObs.observe(el));

// ── 4. STAGGERED GALLERY ──
const galleryGroups = new Map();
document.querySelectorAll('.gallery-item').forEach(el => {
  const parent = el.parentElement;
  if (!galleryGroups.has(parent)) galleryGroups.set(parent, []);
  galleryGroups.get(parent).push(el);
});
const galleryObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const siblings = galleryGroups.get(e.target.parentElement) || [];
      const idx = siblings.indexOf(e.target);
      setTimeout(() => e.target.classList.add('gallery-visible'), idx * 150);
      galleryObs.unobserve(e.target);
    }
  });
}, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });
document.querySelectorAll('.gallery-item').forEach(el => galleryObs.observe(el));
</script>

<style is:global>
/* ── STAGGERED GALLERY ── */
.gallery-item{
  opacity:0;
  transform:translateY(48px);
  transition:opacity .9s cubic-bezier(.22,1,.36,1),transform .9s cubic-bezier(.22,1,.36,1);
}
.gallery-item.gallery-visible{opacity:1;transform:translateY(0);}

/* ── MARQUEE ── */
.marquee-wrap{overflow:hidden;width:100%;background:var(--beige);padding:1.5rem 0;border-top:1px solid rgba(168,201,106,.25);border-bottom:1px solid rgba(168,201,106,.25);}
.marquee-track{display:flex;width:max-content;animation:marquee-scroll 32s linear infinite;}
.marquee-wrap:hover .marquee-track{animation-play-state:paused;}
@keyframes marquee-scroll{from{transform:translateX(0);}to{transform:translateX(-50%);}}
.marquee-item{display:flex;align-items:center;gap:.6rem;padding:0 2.5rem;font-family:var(--f-body);font-size:.72rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--sage);white-space:nowrap;}
.marquee-dot{width:5px;height:5px;border-radius:50%;background:var(--green);flex-shrink:0;}
</style>
