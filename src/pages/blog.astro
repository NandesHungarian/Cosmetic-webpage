---
/**
 * src/pages/blog.astro
 * Magyar blog lista — /blog
 */
import { getCollection } from 'astro:content';
import { t } from '../i18n/v3/index';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const tr = t('hu');
const posts = (await getCollection('blog', ({ data }) => data.lang === 'hu'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const fmt = new Intl.DateTimeFormat('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' });
---

<!DOCTYPE html>
<html lang="hu">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog — Hancz Marianna szépségterapeuta</title>
  <meta name="description" content="Bőrápolási tippek, kezelési útmutatók és szépségipari újdonságok Hancz Mariannától." />
  <link rel="canonical" href="https://szepsegterapeuta.hu/blog" />
  <link rel="alternate" hreflang="en" href="https://szepsegterapeuta.hu/en/blog" />
  <link rel="alternate" hreflang="x-default" href="https://szepsegterapeuta.hu/blog" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <Nav tr={tr} locale="hu" />

  <main class="blog-main">
    <header class="blog-header reveal">
      <span class="eyebrow">Blog</span>
      <h1>Bőrápolási <em>útmutató</em></h1>
      <p class="blog-sub">Tippek, kezelési ismeretek és szépségipari újdonságok.</p>
    </header>

    <section class="blog-grid">
      {posts.length === 0 && (
        <p class="blog-empty">Hamarosan érkeznek az első cikkek.</p>
      )}
      {posts.map((post, i) => (
        <a href={`/blog/${post.slug}`} class={`blog-card reveal d${(i % 3) + 1}`}>
          <div class="blog-card-body">
            <time class="blog-date" datetime={post.data.pubDate.toISOString()}>
              {fmt.format(post.data.pubDate)}
            </time>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-desc">{post.data.description}</p>
          </div>
          <span class="blog-card-cta">Elolvasom →</span>
        </a>
      ))}
    </section>
  </main>

  <Footer tr={tr} locale="hu" />

  <script>
    const io = new IntersectionObserver(
      (es) => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
      { threshold: .12 }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    const burger = document.getElementById('burger');
    const drawer = document.getElementById('drawer');
    burger?.addEventListener('click', () => {
      burger.classList.toggle('open');
      drawer?.classList.toggle('open');
    });
    drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      burger?.classList.remove('open');
      drawer.classList.remove('open');
    }));
  </script>
</body>
</html>

<style>
  .blog-main { padding-top: 62px; min-height: 80vh; }

  .blog-header {
    max-width: 720px;
    margin: 0 auto;
    padding: 3.5rem var(--page-margin) 2rem;
  }
  .blog-header h1 { font-size: clamp(2rem, 5vw, 3rem); margin-bottom: .6rem; }
  .blog-sub { font-size: var(--section-body); color: var(--muted); max-width: 52ch; }

  .blog-grid {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 var(--page-margin) 5rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: 1.25rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: #fff;
    border-radius: 14px;
    padding: 1.6rem 1.5rem 1.3rem;
    border: 1px solid var(--line);
    transition: box-shadow .25s, transform .25s;
    cursor: pointer;
  }
  .blog-card:hover {
    box-shadow: 0 8px 28px rgba(58,63,62,.1);
    transform: translateY(-3px);
  }

  .blog-card-body { flex: 1; }
  .blog-date {
    display: block;
    font-size: .68rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--green-deep);
    margin-bottom: .7rem;
  }
  .blog-card-title {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: .6rem;
    color: var(--ink);
  }
  .blog-card-desc {
    font-size: .8rem;
    color: var(--muted);
    line-height: 1.6;
  }
  .blog-card-cta {
    display: inline-block;
    margin-top: 1.2rem;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .06em;
    color: var(--green-deep);
  }
  .blog-empty {
    color: var(--muted);
    font-size: var(--section-body);
    padding: 2rem 0;
  }
</style>
