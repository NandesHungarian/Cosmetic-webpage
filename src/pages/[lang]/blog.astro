---
import { getCollection } from 'astro:content';
import { t, LOCALES, DEFAULT_LOCALE, alternateUrls, type Locale } from '../../i18n/v3/index';
import '../../styles/global.css';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return LOCALES
    .filter(locale => locale !== DEFAULT_LOCALE)
    .map(locale => ({ params: { lang: locale } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const tr = t(locale);
const alts = alternateUrls('/blog');

const localeDateFormat: Record<Locale, string> = {
  hu: 'hu-HU',
  en: 'en-GB',
  ja: 'ja-JP',
  ko: 'ko-KR',
};

const posts = (await getCollection('blog', ({ data }) => data.lang === locale))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!DOCTYPE html>
<html lang={tr.meta.lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={tr.meta.description} />
  <title>Blog — {tr.meta.title}</title>
  {Object.entries(alts).map(([l, href]) => (
    <link rel="alternate" hreflang={l} href={`https://szepsegterapeuta.hu${href}`} />
  ))}
  <link rel="alternate" hreflang="x-default" href="https://szepsegterapeuta.hu/blog" />
  <link rel="canonical" href={`https://szepsegterapeuta.hu/${locale}/blog`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <script is:inline>
    if (window.location.hash) history.replaceState(null, '', window.location.pathname);
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
    if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  </script>
</head>
<body>
  <Nav tr={tr} locale={locale} />

  <main class="blog-main">
    <header class="blog-header">
      <p class="blog-eyebrow">{locale === 'ja' ? 'ナレッジベース' : locale === 'ko' ? '지식 베이스' : 'Knowledge base'}</p>
      <h1 class="blog-title">Skincare <em>tips</em> and advice</h1>
      <p class="blog-sub">Professional content for the health and natural radiance of your skin.</p>
    </header>

    <section class="blog-grid">
      {posts.map(post => (
        <a href={`/${locale}/blog/${post.id}`} class="blog-card">
          <div class="blog-card-body">
            <time class="blog-date" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString(localeDateFormat[locale], { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-desc">{post.data.description}</p>
          </div>
          <span class="blog-card-cta">
            {locale === 'ja' ? '続きを読む' : locale === 'ko' ? '더 읽기' : 'Read more'}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      ))}
    </section>
  </main>

  <Footer tr={tr} locale={locale} />

  <style>
    body { background: var(--bg, #f2f4ef); }
    .blog-main { max-width: 900px; margin: 0 auto; padding: 7rem 1.5rem 5rem; }
    .blog-header { text-align: center; margin-bottom: 3.5rem; }
    .blog-eyebrow { font-family: var(--sans, 'Inter', sans-serif); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green, #7fa852); margin-bottom: 0.75rem; }
    .blog-title { font-family: var(--serif, 'Playfair Display', Georgia, serif); font-size: clamp(2rem, 5vw, 3rem); font-weight: 400; color: var(--ink, #2a2e27); line-height: 1.15; margin-bottom: 1rem; }
    .blog-title em { font-style: italic; color: var(--green, #7fa852); }
    .blog-sub { font-family: var(--sans, 'Inter', sans-serif); font-size: 1rem; color: var(--muted, #6b7468); max-width: 50ch; margin: 0 auto; line-height: 1.6; }
    .blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(340px, 100%), 1fr)); gap: 1.5rem; }
    .blog-card { background: #fff; border-radius: 14px; border: 1px solid rgba(0,0,0,0.07); padding: 1.75rem; display: flex; flex-direction: column; justify-content: space-between; gap: 1.25rem; text-decoration: none; color: inherit; transition: transform 0.22s cubic-bezier(0.16,1,0.3,1), box-shadow 0.22s cubic-bezier(0.16,1,0.3,1); }
    .blog-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(80,100,60,0.1); }
    .blog-card-body { display: flex; flex-direction: column; gap: 0.6rem; }
    .blog-date { font-family: var(--sans, 'Inter', sans-serif); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted, #6b7468); }
    .blog-card-title { font-family: var(--serif, 'Playfair Display', Georgia, serif); font-size: 1.25rem; font-weight: 500; color: var(--ink, #2a2e27); line-height: 1.3; }
    .blog-card-desc { font-family: var(--sans, 'Inter', sans-serif); font-size: 0.875rem; color: var(--muted, #6b7468); line-height: 1.6; }
    .blog-card-cta { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--sans, 'Inter', sans-serif); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--green, #7fa852); }
  </style>

  <script>
    const burger = document.getElementById('burger');
    const drawer = document.getElementById('drawer');
    burger?.addEventListener('click', () => { burger.classList.toggle('open'); drawer?.classList.toggle('open'); });
    drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => { burger?.classList.remove('open'); drawer.classList.remove('open'); }));
  </script>
</body>
</html>
