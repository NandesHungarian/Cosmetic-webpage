---
import { getCollection, render } from 'astro:content';
import { t, LOCALES, DEFAULT_LOCALE, type Locale } from '../../../i18n/v3/index';
import '../../../styles/global.css';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';

const slugOf = (id: string) => id.split('/').slice(1).join('/');

export async function getStaticPaths() {
  const slugOf = (id: string) => id.split('/').slice(1).join('/');
  const locales = LOCALES.filter(l => l !== DEFAULT_LOCALE);
  const paths = [];
  for (const locale of locales) {
    const posts = await getCollection('blog', ({ data }) => data.lang === locale);
    for (const post of posts) {
      paths.push({ params: { lang: locale, slug: slugOf(post.id) } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
const locale = lang as Locale;
const posts = await getCollection('blog', ({ data }) => data.lang === locale);
const post = posts.find(p => slugOf(p.id) === slug);
if (!post) return Astro.redirect(`/${locale}/blog`);

const { Content } = await render(post);
const tr = t(locale);

const localeDateFormat: Record<Locale, string> = {
  hu: 'hu-HU',
  en: 'en-GB',
  ja: 'ja-JP',
  ko: 'ko-KR',
};

const backLabel: Record<Locale, string> = {
  hu: 'Vissza a bloghoz',
  en: 'Back to blog',
  ja: 'ブログに戻る',
  ko: '블로그로 돌아가기',
};
---

<!DOCTYPE html>
<html lang={tr.meta.lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={post.data.description} />
  <title>{post.data.title} — {tr.meta.title}</title>
  <link rel="canonical" href={`https://szepsegterapeuta.hu/${locale}/blog/${slugOf(post.id)}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <script is:inline>
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
    if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  </script>
</head>
<body>
  <Nav tr={tr} locale={locale} />
  <main class="article-main">
    <a href={`/${locale}/blog`} class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      {backLabel[locale]}
    </a>
    <article>
      <header class="article-header">
        <time class="article-date" datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString(localeDateFormat[locale], { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="article-title">{post.data.title}</h1>
        <p class="article-desc">{post.data.description}</p>
      </header>
      <div class="article-body"><Content /></div>
    </article>
  </main>
  <Footer tr={tr} locale={locale} />

  <style>
    body { background: var(--bg, #f2f4ef); }

    .article-main {
      max-width: 720px;
      margin: 0 auto;
      padding: 7rem 1.5rem 5rem;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--sans, 'Inter', sans-serif);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted, #6b7468);
      text-decoration: none;
      margin-bottom: 2.5rem;
      transition: color 0.18s;
    }
    .back-link:hover { color: var(--green, #7fa852); }

    .article-header {
      margin-bottom: 2.5rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid rgba(0,0,0,0.08);
    }
    .article-date {
      display: block;
      font-family: var(--sans, 'Inter', sans-serif);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--green, #7fa852);
      margin-bottom: 0.75rem;
    }
    .article-title {
      font-family: var(--serif, 'Playfair Display', Georgia, serif);
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 400;
      color: var(--ink, #2a2e27);
      line-height: 1.2;
      margin-bottom: 1rem;
    }
    .article-desc {
      font-family: var(--sans, 'Inter', sans-serif);
      font-size: 1.05rem;
      color: var(--ink, #2a2e27);
      line-height: 1.65;
      opacity: 0.7;
    }

    .article-body {
      font-family: var(--sans, 'Inter', sans-serif);
      font-size: 1rem;
      line-height: 1.8;
      color: var(--ink, #2a2e27);
      font-feature-settings: 'liga' 1, 'kern' 1;
    }

    .article-body :global(h2) {
      font-family: var(--serif, 'Playfair Display', Georgia, serif);
      font-size: clamp(1.2rem, 2.5vw, 1.5rem);
      font-weight: 500;
      color: var(--ink, #2a2e27);
      margin-top: 2.75rem;
      margin-bottom: 0.875rem;
      line-height: 1.25;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid rgba(0,0,0,0.07);
    }

    .article-body :global(h3) {
      font-family: var(--sans, 'Inter', sans-serif);
      font-size: 1rem;
      font-weight: 700;
      color: var(--ink, #2a2e27);
      margin-top: 1.75rem;
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }

    .article-body :global(p) {
      color: var(--ink, #2a2e27);
      margin-bottom: 1.35rem;
      max-width: 68ch;
    }

    .article-body :global(ul),
    .article-body :global(ol) {
      color: var(--ink, #2a2e27);
      padding-left: 1.5rem;
      margin-bottom: 1.35rem;
    }
    .article-body :global(li) {
      color: var(--ink, #2a2e27);
      margin-bottom: 0.45rem;
      line-height: 1.75;
    }
    .article-body :global(li)::marker {
      color: var(--green, #7fa852);
    }

    .article-body :global(a) {
      color: var(--green, #7fa852);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-thickness: 1px;
    }
    .article-body :global(a:hover) {
      color: var(--green-deep, #5a7a3a);
    }

    .article-body :global(blockquote) {
      border-left: 3px solid var(--green, #7fa852);
      margin: 1.75rem 0;
      padding: 0.75rem 1.25rem;
      background: rgba(127,168,82,0.06);
      border-radius: 0 6px 6px 0;
      font-style: italic;
      color: var(--ink, #2a2e27);
    }
    .article-body :global(blockquote p) {
      margin-bottom: 0;
    }

    .article-body :global(code) {
      font-family: 'Menlo', 'Consolas', monospace;
      font-size: 0.875em;
      background: rgba(0,0,0,0.05);
      padding: 0.15em 0.4em;
      border-radius: 4px;
      color: var(--ink, #2a2e27);
    }

    .article-body :global(hr) {
      border: none;
      border-top: 1px solid rgba(0,0,0,0.08);
      margin: 2.5rem 0;
    }

    .article-body :global(p:first-child),
    .article-body :global(> *:first-child) {
      margin-top: 0;
    }
  </style>

  <script>
    const burger = document.getElementById('burger');
    const drawer = document.getElementById('drawer');
    burger?.addEventListener('click', () => { burger.classList.toggle('open'); drawer?.classList.toggle('open'); });
    drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => { burger?.classList.remove('open'); drawer.classList.remove('open'); }));
  </script>
</body>
</html>
