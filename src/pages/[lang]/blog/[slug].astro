/**
 * src/pages/[lang]/blog/[slug].astro
 * ─────────────────────────────────────────────────────
 * Minden nem-magyar locale blog cikk oldala egyetlen fájlból.
 * - /en/blog/:slug  → angol cikk
 * - /ja/blog/:slug  → japán cikk
 * - /ko/blog/:slug  → koreai cikk
 *
 * A magyar cikk oldal: src/pages/blog/[slug].astro
 */
import { getCollection } from 'astro:content';
import { t, LOCALES, DEFAULT_LOCALE, type Locale } from '../../../i18n/v3/index';
import '../../../styles/global.css';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';

export async function getStaticPaths() {
  const locales = LOCALES.filter(l => l !== DEFAULT_LOCALE);
  const paths = [];
  for (const locale of locales) {
    const posts = await getCollection('blog', ({ data }) => data.lang === locale);
    for (const post of posts) {
      paths.push({ params: { lang: locale, slug: post.slug } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
const locale = lang as Locale;
const posts = await getCollection('blog', ({ data }) => data.lang === locale);
const post = posts.find(p => p.slug === slug);
if (!post) return Astro.redirect(`/${locale}/blog`);

const { Content } = await post.render();
const tr = t(locale);

const localeDateFormat: Record<Locale, string> = {
  hu: 'hu-HU',
  en: 'en-GB',
  ja: 'ja-JP',
  ko: 'ko-KR',
};

const backLabel: Record<Locale, string> = {
  hu: 'Vissza a bloghoz',
  en: 'Back to blog',
  ja: 'ブログに戻る',
  ko: '블로그로 돌아가기',
};
---

<!DOCTYPE html>
<html lang={tr.meta.lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={post.data.description} />
  <title>{post.data.title} — {tr.meta.title}</title>
  <link rel="canonical" href={`https://szepsegterapeuta.hu/${locale}/blog/${post.slug}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <script is:inline>
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
    if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  </script>
</head>
<body>
  <Nav tr={tr} locale={locale} />

  <main class="article-main">
    <a href={`/${locale}/blog`} class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      {backLabel[locale]}
    </a>

    <article>
      <header class="article-header">
        <time class="article-date" datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString(localeDateFormat[locale], { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="article-title">{post.data.title}</h1>
        <p class="article-desc">{post.data.description}</p>
      </header>
      <div class="article-body"><Content /></div>
    </article>
  </main>

  <Footer tr={tr} locale={locale} />

  <style>
    body { background: var(--bg, #f2f4ef); }
    .article-main { max-width: 720px; margin: 0 auto; padding: 7rem 1.5rem 5rem; }
    .back-link { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--sans, 'Inter', sans-serif); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted, #6b7468); text-decoration: none; margin-bottom: 2.5rem; transition: color 0.18s; }
    .back-link:hover { color: var(--green, #7fa852); }
    .article-header { margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(0,0,0,0.08); }
    .article-date { display: block; font-family: var(--sans, 'Inter', sans-serif); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--green, #7fa852); margin-bottom: 0.75rem; }
    .article-title { font-family: var(--serif, 'Playfair Display', Georgia, serif); font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 400; color: var(--ink, #2a2e27); line-height: 1.2; margin-bottom: 1rem; }
    .article-desc { font-family: var(--sans, 'Inter', sans-serif); font-size: 1.05rem; color: var(--muted, #6b7468); line-height: 1.65; }
    .article-body { font-family: var(--sans, 'Inter', sans-serif); font-size: 1rem; line-height: 1.75; color: var(--ink, #2a2e27); }
    .article-body h2 { font-family: var(--serif, 'Playfair Display', Georgia, serif); font-size: 1.4rem; font-weight: 500; color: var(--ink, #2a2e27); margin: 2.25rem 0 0.75rem; line-height: 1.25; }
    .article-body p { margin-bottom: 1.25rem; max-width: 65ch; }
    .article-body ul { padding-left: 1.25rem; margin-bottom: 1.25rem; }
    .article-body li { margin-bottom: 0.4rem; line-height: 1.65; }
    .article-body a { color: var(--green, #7fa852); text-decoration: underline; text-underline-offset: 3px; }
    .article-body a:hover { color: var(--green-deep, #5a7a3a); }
  </style>

  <script>
    const burger = document.getElementById('burger');
    const drawer = document.getElementById('drawer');
    burger?.addEventListener('click', () => { burger.classList.toggle('open'); drawer?.classList.toggle('open'); });
    drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => { burger?.classList.remove('open'); drawer.classList.remove('open'); }));
  </script>
</body>
</html>
