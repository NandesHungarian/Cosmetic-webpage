---
// ░ ARCHÍV — a régi (sima) főoldal, megmarad referenciának ░
import Layout from '../../layouts/Layout.astro';
import Animations from '../../components/Animations.astro';
import { getSection } from '../../i18n/utils';

const locale = 'hu';
const meta         = getSection<any>(locale, 'meta');
const hero         = getSection<any>(locale, 'hero');
const about        = getSection<any>(locale, 'about');
const services     = getSection<any>(locale, 'services');
const testimonials = getSection<any>(locale, 'testimonials');
const faq          = getSection<any>(locale, 'faq');
const contact      = getSection<any>(locale, 'contact');

const posts = [
  {
    img: 'https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=600&q=80',
    tag: 'Trendek',
    date: '2026. máj. 25.',
    title: 'Hová tart a kozmetika 2026-ban?',
    excerpt: 'A szakma ma már nem csak krémekről szól — a személyre szabás, a skinimalizmus és az okos technológia együtt formálja a bőrápolás jövőjét.',
    body: `A kozmetika ma már messze nem csak a „szépítő kezelésekről\" szól. Az elmúlt években a szakma látványosan elmozdult abba az irányba, hogy a bőrápolás egyszerre legyen tudatosabb, személyre szabottabb és tudományosabban megalapozott. Ez a változás a hétköznapi vendégek számára is jól látható: egyre többen keresnek olyan megoldásokat, amelyek nem ígérnek csodát egyik napról a másikra, hanem valóban a bőr állapotához, életmódjához és érzékenységéhez igazodnak.\n\nAz egyik legerősebb irány a skinimalizmus, vagyis a kevesebb, de okosan megválasztott termékek használata. A korábbi „minél több, annál jobb\" szemlélet helyett ma sok szakember azt vallja, hogy a bőr gyakran jobban reagál egy egyszerűbb, átgondolt rutinra.\n\nEzzel párhuzamosan egyre fontosabbá válik a személyre szabás. Ugyanaz a krém, ugyanaz a kezelés vagy ugyanaz a hatóanyag nem működik mindenkinél egyformán.\n\nA technológia közben egyre látványosabban belép ebbe a világba. A bőrértékelésben megjelentek a digitális eszközök, az intelligensebb diagnosztikai rendszerek és a hatóanyagok célzottabb bejuttatására szolgáló fejlesztések is.\n\nA kozmetika jövője tehát nem a túlzásokról szól, hanem a tudatosságról. Kevesebb ígéret, több valódi figyelem.`,
    sources: [
      { label: 'Artificial intelligence in cosmetic dermatology (PubMed, 2024)', url: 'https://pubmed.ncbi.nlm.nih.gov/39188183/' },
      { label: 'Nanocarriers in skincare: current trends (PubMed, 2025)', url: 'https://pubmed.ncbi.nlm.nih.gov/41014067/' },
      { label: 'Evaluating efficacy and innovation in skin care (PMC, 2025)', url: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC12408269/' },
    ]
  },
  {
    img: 'https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?w=600&q=80',
    tag: 'Szakmai',
    date: '2026. máj. 25.',
    title: 'Mennyire hatásosak valójában a kozmetikai termékek?',
    excerpt: 'A dobozon szereplő ígéret és a valódi tudományos bizonyíték között sokszor komoly a szakadék.',
    body: `Sokan ma is úgy vesznek kozmetikumot, mintha a dobozon szereplő ígéret önmagában garancia lenne az eredményre. A valóság ennél jóval összetettebb.\n\nA kozmetikus szerepe ezért nem egyszerűen az, hogy terméket ajánljon, hanem az, hogy elmagyarázza: a bőrön mérhető javulás időt, következetes használatot és megfelelő rutinba illesztést igényel.`,
    sources: [
      { label: 'Efficacy of fermented lysate in anti-aging cosmetics (PubMed, 2024)', url: 'https://pubmed.ncbi.nlm.nih.gov/37977853/' },
      { label: 'Anti-wrinkle efficacy of phenolic acids (PubMed, 2024)', url: 'https://pubmed.ncbi.nlm.nih.gov/38943252/' },
    ]
  },
  {
    img: 'https://images.unsplash.com/photo-1556228578-8c89e6adf883?w=600&q=80',
    tag: 'Fenntarthatóság',
    date: '2026. máj. 25.',
    title: 'Fenntartható kozmetika: divat vagy tartós irány?',
    excerpt: 'A „természetes\" és „bio\" jelzők mögött nem mindig van, amit gondolunk.',
    body: `A fenntarthatóság ma már nem külön „szépészeti extra\", hanem a kozmetikai ipar egyik komoly fejlődési iránya.\n\nFontos azonban, hogy a fenntarthatóságot ne keverjük össze automatikusan a „természetes\" vagy „bio\" jelzővel.`,
    sources: [
      { label: 'Sustainability in Cosmetic Dermatology (PMC, 2025)', url: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC12454804/' },
    ]
  },
];
---

<Layout locale={locale} title={meta.title} description={meta.description}>
  <section class="archive-banner">
    <p>⚠️ Ez az archív oldal. A főoldal: <a href="/">szepsegterapeuta.hu</a></p>
  </section>
  <Animations />
</Layout>

<style>
.archive-banner { background: #fffbe6; border: 1px solid #f0e68c; padding: 1rem 2rem; text-align: center; font-size: 0.9rem; color: #7a6a00; }
.archive-banner a { color: #4a7c59; font-weight: 700; }
</style>