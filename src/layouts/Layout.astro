---
import type { Locale } from '../i18n/utils';
import { getSection, localePath, SUPPORTED_LOCALES } from '../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description: string;
}

const { locale, title, description } = Astro.props;
const nav = getSection<any>(locale, 'nav');
const footer = getSection<any>(locale, 'footer');

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BeautySalon',
  name: 'Hancz Marianna Szépségterapeuta',
  url: 'https://szepsegterapeuta.hu',
  telephone: '+36-20-339-3399',
  email: 'info@szepsegterapeuta.hu',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Dolgos utca 2. 6B lépcsőház',
    addressLocality: 'Budapest',
    postalCode: '1126',
    addressCountry: 'HU'
  },
  openingHours: 'Mo-Su 06:00-20:00',
  description
});
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="canonical" href={`https://szepsegterapeuta.hu${localePath(locale)}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={schema} />
</head>

<body>

  <!-- NAV -->
  <header class="site-nav" id="site-nav">
    <div class="nav-wrap">

      <!-- Bal: logo -->
      <a href={localePath(locale)} class="nav-logo" aria-label="Főoldal">
        <img src="/logo.svg" alt="Szépségterapeuta" width="150" height="42" />
      </a>

      <!-- Közép: nav linkek (desktop) -->
      <nav class="desktop-nav" aria-label="Főnavigáció">
        <ul>
          <li><a href={`${localePath(locale)}#services`}>{nav.services}</a></li>
          <li><a href={`${localePath(locale)}#about`}>{nav.about}</a></li>
          <li><a href={`${localePath(locale)}#contact`}>{nav.contact}</a></li>
        </ul>
      </nav>

      <!-- Jobb: nyelvváltó + CTA (desktop) -->
      <div class="nav-end">
        <div class="lang-row">
          {SUPPORTED_LOCALES.map(l => (
            <a href={localePath(l)} class={`lbtn${l === locale ? ' on' : ''}`} hreflang={l}>
              {l.toUpperCase()}
            </a>
          ))}
        </div>
        <a href={`${localePath(locale)}#contact`} class="cta-pill">{nav.book}</a>
      </div>

      <!-- Hamburger (csak mobilon, JOBB oldalon) -->
      <button class="burger" id="burger" aria-label="Menü" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>

    </div>

    <!-- Mobil menü -->
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      <ul>
        <li><a href={`${localePath(locale)}#services`}>{nav.services}</a></li>
        <li><a href={`${localePath(locale)}#about`}>{nav.about}</a></li>
        <li><a href={`${localePath(locale)}#contact`}>{nav.contact}</a></li>
      </ul>
      <div class="mobile-lang">
        {SUPPORTED_LOCALES.map(l => (
          <a href={localePath(l)} class={`lbtn${l === locale ? ' on' : ''}`} hreflang={l}>
            {l.toUpperCase()}
          </a>
        ))}
      </div>
      <a href={`${localePath(locale)}#contact`} class="cta-pill mobile-cta">{nav.book}</a>
    </div>
  </header>

  <main><slot /></main>

  <footer class="site-footer">
    <p class="ft-quote">{footer.tagline}</p>
    <p class="ft-copy">{footer.copyright}</p>
  </footer>

  <!-- Burger JS -->
  <script>
    const burger = document.getElementById('burger');
    const menu   = document.getElementById('mobile-menu');

    burger?.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!open));
      menu?.setAttribute('aria-hidden', String(open));
      burger.classList.toggle('is-open', !open);
      menu?.classList.toggle('is-open', !open);
    });

    menu?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        burger?.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        burger?.classList.remove('is-open');
        menu.classList.remove('is-open');
      });
    });
  </script>

</body>
</html>

<style is:global>
  /* ── DESIGN TOKENS (brand guideline alapján) ── */
  :root {
    --c-fresh:  #A8C96A;   /* Fresh Green – fő akcentus */
    --c-sage:   #6E8467;   /* Sage Green – mélyebb hangsúly */
    --c-cream:  #FAF9F6;   /* Cream White – alap háttér */
    --c-beige:  #EDE5D6;   /* Warm Beige – melegsemleges */
    --c-gray:   #F2F2F2;   /* Light Gray – finom kiegészítő */
    --c-stone:  #DDD8CE;   /* elválasztók */
    --c-ink:    #2C2C2C;   /* szöveg */
    --c-muted:  #7A7570;   /* másodlagos szöveg */
    --f-serif:  'Playfair Display', Georgia, serif;
    --f-sans:   'Lato', system-ui, sans-serif;
    --mw:       1160px;
    --ease:     0.3s ease;
    --nav-h:    68px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    overflow-x: hidden;
    width: 100%;
  }

  html { scroll-behavior: smooth; }
  body {
    font-family: var(--f-sans);
    font-weight: 300;
    background: var(--c-cream);
    color: var(--c-ink);
    line-height: 1.75;
    -webkit-font-smoothing: antialiased;
  }
  h1,h2,h3,h4 { font-family: var(--f-serif); font-weight: 400; line-height: 1.2; }
  img { max-width: 100%; height: auto; display: block; }
  a { color: inherit; }

  /* ── NAV ── */
  .site-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 500;
    background: rgba(250,249,246,0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--c-stone);
  }
  .nav-wrap {
    max-width: var(--mw); margin: 0 auto;
    height: var(--nav-h);
    padding: 0 2rem;
    display: flex; align-items: center; gap: 2rem;
  }
  /* Logo bal oldalon */
  .nav-logo { text-decoration: none; flex-shrink: 0; }
  /* Navigáció középen */
  .desktop-nav { flex: 1; }
  .desktop-nav ul { list-style: none; display: flex; gap: 2.5rem; justify-content: center; }
  .desktop-nav a {
    text-decoration: none;
    font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--c-muted); transition: color var(--ease);
  }
  .desktop-nav a:hover { color: var(--c-sage); }
  .nav-end { display: flex; align-items: center; gap: 1.25rem; margin-left: auto; }

  main { padding-top: var(--nav-h); }

  /* ── NYELVVÁLTÓ ── */
  .lang-row { display: flex; gap: 0.1rem; }
  .lbtn {
    font-family: var(--f-sans); font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.08em; text-decoration: none;
    color: var(--c-muted); padding: 0.3rem 0.45rem;
    border-radius: 3px; transition: all var(--ease);
  }
  .lbtn:hover { color: var(--c-ink); }
  .lbtn.on { color: var(--c-fresh); }

  /* ── GOMBOK ── */
  .cta-pill {
    display: inline-block; text-decoration: none;
    background: var(--c-fresh); color: #fff;
    font-family: var(--f-sans); font-size: 0.75rem;
    font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.65rem 1.6rem; border-radius: 4px;
    transition: background var(--ease), transform var(--ease);
    border: none; cursor: pointer; white-space: nowrap;
  }
  .cta-pill:hover { background: var(--c-sage); transform: translateY(-1px); }
  .cta-ghost {
    display: inline-block; text-decoration: none;
    background: transparent; color: var(--c-sage);
    font-family: var(--f-sans); font-size: 0.75rem;
    font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.65rem 1.6rem; border-radius: 4px;
    border: 1.5px solid var(--c-sage); transition: all var(--ease);
  }
  .cta-ghost:hover { background: var(--c-sage); color: #fff; }

  /* ── BURGER (csak mobilon, jobb oldalon) ── */
  .burger {
    display: none;
    flex-direction: column; justify-content: center;
    gap: 5px; width: 36px; height: 36px;
    background: none; border: none; cursor: pointer;
    padding: 4px; flex-shrink: 0;
    margin-left: auto;
  }
  .burger span {
    display: block; height: 2px; width: 100%;
    background: var(--c-sage);
    transition: transform var(--ease), opacity var(--ease);
    transform-origin: center;
  }
  .burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger.is-open span:nth-child(2) { opacity: 0; }
  .burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── MOBIL MENÜ ── */
  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 0;
    background: var(--c-cream);
    border-top: 1px solid var(--c-stone);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.4s ease;
  }
  .mobile-menu.is-open { max-height: 480px; }
  .mobile-menu ul { list-style: none; }
  .mobile-menu ul li a {
    display: block;
    padding: 1.1rem 2rem;
    font-size: 0.85rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    text-decoration: none; color: var(--c-ink);
    border-bottom: 1px solid var(--c-stone);
    transition: color var(--ease);
  }
  .mobile-menu ul li a:hover { color: var(--c-fresh); }
  .mobile-lang {
    display: flex; gap: 0.5rem;
    padding: 1rem 2rem;
    border-bottom: 1px solid var(--c-stone);
  }
  .mobile-cta { margin: 1.25rem 2rem 1.5rem; align-self: flex-start; }

  /* ── GLOBÁLIS SZEKCIÓK ── */
  .sec { padding: clamp(3.5rem,8vw,8rem) 2rem; }
  .sec-inner { max-width: var(--mw); margin: 0 auto; }
  .sec-label {
    display: block; font-family: var(--f-sans);
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--c-fresh); margin-bottom: 0.9rem;
  }
  .sec-head { text-align: center; margin-bottom: 4rem; }
  .sec-head h2 { font-size: clamp(1.9rem,4.5vw,3rem); margin-bottom: 0.5rem; }
  .sec-head p { color: var(--c-muted); max-width: 520px; margin: 0 auto; font-size: 0.95rem; }
  .divider { width: 44px; height: 2px; background: var(--c-fresh); margin: 1.25rem auto; }

  /* ── FOOTER ── */
  .site-footer {
    background: var(--c-sage); color: rgba(255,255,255,0.85);
    text-align: center; padding: 3.5rem 2rem;
  }
  .ft-quote {
    font-family: var(--f-serif); font-style: italic;
    font-size: 1.2rem; color: #fff;
    margin-bottom: 0.6rem;
  }
  .ft-copy { font-size: 0.72rem; letter-spacing: 0.05em; }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .desktop-nav { display: none; }
    .nav-end { display: none; }
    .burger { display: flex; }
    .nav-logo { margin-left: 0; }
    .mobile-menu { display: flex; }
    .nav-wrap { padding: 0 1.25rem; }
    .sec { padding: clamp(2.5rem,7vw,5rem) 1.25rem; }
  }
</style>
