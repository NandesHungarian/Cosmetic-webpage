---
import type { Locale } from '../i18n/utils';
import { getSection, localePath, SUPPORTED_LOCALES } from '../i18n/utils';

interface Props {
  locale: Locale;
  title: string;
  description: string;
}

const { locale, title, description } = Astro.props;
const nav = getSection<any>(locale, 'nav');
const footer = getSection<any>(locale, 'footer');

const schema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BeautySalon',
  name: 'Hancz Marianna Szépségterapeuta',
  url: 'https://szepsegterapeuta.hu',
  telephone: '+36-20-339-3399',
  email: 'info@szepsegterapeuta.hu',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Dolgos utca 2. 6B lépcsőház',
    addressLocality: 'Budapest',
    postalCode: '1126',
    addressCountry: 'HU'
  },
  openingHours: 'Mo-Su 06:00-20:00',
  description
});
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="canonical" href={`https://szepsegterapeuta.hu${localePath(locale)}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={schema} />
</head>

<body>
  <header class="site-nav" id="site-nav">
    <div class="nav-wrap">
      <button class="burger" id="burger" aria-label="Menü" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
      <a href={localePath(locale)} class="nav-logo" aria-label="Főoldal">
        <img src="/logo.svg" alt="Szépségterapeuta" width="160" height="44" />
      </a>
      <nav class="desktop-nav" aria-label="Főnavigáció">
        <ul>
          <li><a href={`${localePath(locale)}#services`}>{nav.services}</a></li>
          <li><a href={`${localePath(locale)}#about`}>{nav.about}</a></li>
          <li><a href={`${localePath(locale)}#contact`}>{nav.contact}</a></li>
        </ul>
      </nav>
      <div class="nav-end">
        <div class="lang-row">
          {SUPPORTED_LOCALES.map(l => (
            <a href={localePath(l)} class={`lbtn${l === locale ? ' on' : ''}`} hreflang={l}>{l.toUpperCase()}</a>
          ))}
        </div>
        <a href={`${localePath(locale)}#contact`} class="btn-primary">{nav.book}</a>
      </div>
    </div>
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      <ul>
        <li><a href={`${localePath(locale)}#services`}>{nav.services}</a></li>
        <li><a href={`${localePath(locale)}#about`}>{nav.about}</a></li>
        <li><a href={`${localePath(locale)}#contact`}>{nav.contact}</a></li>
      </ul>
      <div class="mobile-lang">
        {SUPPORTED_LOCALES.map(l => (
          <a href={localePath(l)} class={`lbtn${l === locale ? ' on' : ''}`} hreflang={l}>{l.toUpperCase()}</a>
        ))}
      </div>
      <a href={`${localePath(locale)}#contact`} class="btn-primary mobile-cta">{nav.book}</a>
    </div>
  </header>

  <main><slot /></main>

  <footer class="site-footer">
    <div class="footer-logo">
      <img src="/logo.svg" alt="Szépségterapeuta" width="140" height="38" />
    </div>
    <p class="ft-tagline">{footer.tagline}</p>
    <div class="footer-links">
      <a href="#services">{nav.services}</a>
      <a href="#about">{nav.about}</a>
      <a href="#contact">{nav.contact}</a>
    </div>
    <p class="ft-copy">{footer.copyright}</p>
  </footer>

  <script>
    const burger = document.getElementById('burger');
    const menu = document.getElementById('mobile-menu');
    burger?.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!open));
      menu?.setAttribute('aria-hidden', String(open));
      burger.classList.toggle('is-open', !open);
      menu?.classList.toggle('is-open', !open);
    });
    menu?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        burger?.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        burger?.classList.remove('is-open');
        menu.classList.remove('is-open');
      });
    });
  </script>
</body>
</html>

<style is:global>
  :root {
    --green:   #A8C96A;
    --sage:    #6E8467;
    --beige:   #EDE5D6;
    --cream:   #FAF9F6;
    --gray-lt: #F2F2F2;
    --ink:     #2C2C2C;
    --muted:   #7A7A7A;
    --f-head:  'Playfair Display', Georgia, serif;
    --f-body:  'Lato', system-ui, sans-serif;
    --mw:      1200px;
    --ease:    0.3s ease;
    --nav-h:   70px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { overflow-x: hidden; width: 100%; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--f-body);
    font-weight: 300;
    background: var(--cream);
    color: var(--ink);
    line-height: 1.75;
    -webkit-font-smoothing: antialiased;
  }
  h1, h2, h3, h4 { font-family: var(--f-head); font-weight: 400; line-height: 1.2; }
  img { max-width: 100%; height: auto; display: block; }
  a { color: inherit; text-decoration: none; }

  /* ── NAV ── */
  .site-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 500;
    background: rgba(250,249,246,0.97);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(168,201,106,0.2);
  }
  .nav-wrap {
    max-width: var(--mw); margin: 0 auto;
    height: var(--nav-h);
    padding: 0 2rem;
    display: flex; align-items: center; gap: 2rem;
  }
  .nav-logo { flex-shrink: 0; }
  .desktop-nav { margin-left: auto; }
  .desktop-nav ul { list-style: none; display: flex; gap: 2.5rem; }
  .desktop-nav a {
    font-size: 0.8rem; font-weight: 400;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); transition: color var(--ease);
  }
  .desktop-nav a:hover { color: var(--sage); }
  .nav-end { display: flex; align-items: center; gap: 1.5rem; margin-left: 2rem; }
  main { padding-top: var(--nav-h); }

  /* ── LANG ── */
  .lang-row { display: flex; gap: 0.1rem; }
  .lbtn {
    font-family: var(--f-body); font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--muted); padding: 0.3rem 0.4rem;
    border-radius: 3px; transition: color var(--ease);
  }
  .lbtn:hover { color: var(--sage); }
  .lbtn.on { color: var(--sage); }

  /* ── GOMBOK ── */
  .btn-primary {
    display: inline-block;
    background: var(--green); color: #fff;
    font-family: var(--f-body); font-size: 0.78rem;
    font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 0.7rem 1.8rem; border-radius: 4px;
    transition: background var(--ease), transform var(--ease);
    border: none; cursor: pointer; white-space: nowrap;
  }
  .btn-primary:hover { background: var(--sage); transform: translateY(-1px); }
  .btn-outline {
    display: inline-block;
    background: transparent; color: var(--sage);
    font-family: var(--f-body); font-size: 0.78rem;
    font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 0.7rem 1.8rem; border-radius: 4px;
    border: 2px solid var(--sage); transition: all var(--ease);
    cursor: pointer; white-space: nowrap;
  }
  .btn-outline:hover { background: var(--sage); color: #fff; }

  /* ── BURGER ── */
  .burger {
    display: none;
    flex-direction: column; justify-content: center;
    gap: 5px; width: 36px; height: 36px;
    background: none; border: none; cursor: pointer; padding: 4px;
    flex-shrink: 0; order: -1;
  }
  .burger span {
    display: block; height: 2px; width: 100%;
    background: var(--sage);
    transition: transform var(--ease), opacity var(--ease);
    transform-origin: center;
  }
  .burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger.is-open span:nth-child(2) { opacity: 0; }
  .burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── MOBIL MENU ── */
  .mobile-menu {
    display: none;
    flex-direction: column;
    background: var(--cream);
    border-top: 2px solid var(--green);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.4s ease;
  }
  .mobile-menu.is-open { max-height: 520px; }
  .mobile-menu ul { list-style: none; }
  .mobile-menu ul li a {
    display: block; padding: 1rem 1.5rem;
    font-size: 0.85rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--ink); border-bottom: 1px solid rgba(168,201,106,0.2);
    transition: color var(--ease), background var(--ease);
  }
  .mobile-menu ul li a:hover { color: var(--sage); background: var(--gray-lt); }
  .mobile-lang { display: flex; gap: 0.5rem; padding: 0.8rem 1.5rem; border-bottom: 1px solid rgba(168,201,106,0.2); }
  .mobile-cta { margin: 1rem 1.5rem 1.5rem; align-self: flex-start; }

  /* ── SZEKCIÓ ALAP ── */
  .sec { padding: clamp(3.5rem, 8vw, 7rem) 2rem; }
  .sec-inner { max-width: var(--mw); margin: 0 auto; }
  .sec-label {
    display: block; font-family: var(--f-body);
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.25em;
    text-transform: uppercase; color: var(--green); margin-bottom: 0.75rem;
  }
  .sec-head { text-align: center; margin-bottom: 3.5rem; }
  .sec-head h2 { font-size: clamp(1.8rem, 4vw, 2.8rem); color: var(--sage); margin-bottom: 0.5rem; }
  .sec-head p { color: var(--muted); max-width: 520px; margin: 0 auto; font-size: 0.95rem; }
  .divider { width: 50px; height: 2px; background: var(--green); margin: 1rem auto; border-radius: 2px; }

  /* ── FOOTER ── */
  .site-footer {
    background: var(--sage);
    color: rgba(255,255,255,0.85);
    text-align: center;
    padding: 3rem 2rem;
  }
  .footer-logo { margin: 0 auto 1rem; filter: brightness(0) invert(1) opacity(0.9); width: fit-content; }
  .ft-tagline {
    font-family: var(--f-head); font-style: italic;
    font-size: 1.1rem; color: rgba(255,255,255,0.9);
    margin-bottom: 1.5rem;
  }
  .footer-links { display: flex; justify-content: center; gap: 2rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .footer-links a {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(255,255,255,0.7); transition: color var(--ease);
  }
  .footer-links a:hover { color: #fff; }
  .ft-copy { font-size: 0.72rem; color: rgba(255,255,255,0.5); }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .desktop-nav { display: none; }
    .nav-end { display: none; }
    .burger { display: flex; }
    .mobile-menu { display: flex; }
    .nav-wrap { padding: 0 1.25rem; justify-content: space-between; }
    .sec { padding: clamp(2.5rem, 7vw, 4rem) 1.25rem; }
  }
</style>
