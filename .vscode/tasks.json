{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Git Push",
      "type": "shell",
      "command": "git add . && git commit -m \"${input:commitMessage}\" && git push",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "Commit üzenet:",
      "default": "Frissítés"
    }
  ]
}